                                "value": "dog"
                            },
                            {
                                "label": "PF2E.NPCAbility.ChangeShape.Form.Humanoid.Humanoid",
                                "value": "humanoid"
                            }
                        ],
                        "toggleable": true,
                        "value": true
                    },
                    {
                        "attackModifier": 13,
                        "damage": {
                            "base": {
