        {
            "_id": "OYTMM7CJ2SXI9EL3",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Abduct",
            "sort": 1100000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> Dazerien has a Medium or smaller creature @UUID[Compendium.pf2e.conditionitems.Item.Grabbed]</p><hr /><p><strong>Effect</strong> Dazerien attempts to carry off his victim. The grabbed creature attempts a @Check[fortitude|dc:30] save with the following effects.</p><hr /><p><strong>Critical Success</strong> The grabbed creature escapes and is no longer grabbed.</p>\n<p><strong>Success</strong> The grabbed creature remains grabbed.</p>\n<p><strong>Failure</strong> As success, but Dazerien can Stride, and carries the grabbed creature with him. When he's Large as a result of Moon Frenzy, Dazerien can carry up to 22 Bulk without becoming encumbered—generally more than enough to haul away a Medium (6 Bulk) creature with all their gear and armor at full speed.</p>\n<p><strong>Critical Failure</strong> As failure, plus Dazerien gains a +4 circumstance bonus to Athletics on his next attempt to [[/act grapple]] the grabbed creature.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
