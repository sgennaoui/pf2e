        },
        {
            "_id": "ahtVNJjKjna3LTc1",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Alchemical Injection",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>When a noxious needler hits a creature with a syringe Strike, roll 1d6 on the alchemical chambers list to determine the additional effect of the attack. The syringe deals an additional 2d6 damage of the appropriate type (or exposes the target to the sickness effect, as appropriate).</p><table class=\"pf2e remaster\"><thead><tr><th>[[/gmr 1d6 #Alchemical Injection]]</th><th>Alchemical Effect</th></tr></thead><tbody><tr><td>1</td><td><p>@Damage[2d6[acid]] damage</p></td></tr><tr><td>2</td><td>@Damage[2d6[cold]] damage</td></tr><tr><td>3</td><td>@Damage[2d6[electricity]] damage</td></tr><tr><td>4</td><td>@Damage[2d6[fire]] damage</td></tr><tr><td>5</td><td>@Damage[2d6[poison]] damage</td></tr><tr><td>6</td><td>Sickness: @Check[fortitude|dc:26|name:Alchemical Sickness|traits:disease] save or @UUID[Compendium.pf2e.conditionitems.Item.Sickened]{Sickened 1} (@UUID[Compendium.pf2e.conditionitems.Item.Sickened]{Sickened 2} on a critical failure)</td></tr></tbody></table>"
                },
                "publication": {
                    "license": "ORC",
                    "remaster": true,
                    "title": ""
                },
                "rules": [
                    {
                        "alwaysActive": true,
                        "domain": "damage",
                        "key": "RollOption",
                        "option": "alchemical-injection",
                        "selection": "acid",
                        "suboptions": [
                            {
                                "label": "PF2E.TraitAcid",
                                "value": "acid"
                            },
                            {
                                "label": "PF2E.TraitCold",
