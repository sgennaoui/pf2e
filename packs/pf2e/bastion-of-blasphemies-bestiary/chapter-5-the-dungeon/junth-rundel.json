        {
            "_id": "oHG92Hkp1nXgjxm7",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Attach Siphon",
            "sort": 600000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>A creature that takes any damage from a blood siphon Strike must attempt a @Check[reflex|dc:28] save. On a failure, the siphon attaches to the creature. It's attached to Junth by a long length of flexible leather hose, so if he misses with a blood siphon he can retract it as an Interact action. The tether can also be severed (AC 27, Hardness 10, 10 HP), and the creature to which it has been attached can [[/act escape dc=28]].</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
                    "value": []
                }
            },
            "type": "action"
        },
        {
            "_id": "umpCfNNjp3KzvnIX",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Siphon Blood",
            "sort": 700000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> Junth has a blood siphon attached to a target creature</p>\n<p><strong>Frequency</strong> once per round</p><hr /><p><strong>Effect</strong> Junth drains blood from the target creature, dealing @Damage[5d6[bleed]] damage. Unlike most bleed damage, this isn't persistent damage. A creature that takes any of this bleed damage must also attempt a @Check[fortitude|dc:28] save.</p><hr /><p><strong>Critical Success</strong> The creature takes no damage.</p>\n<p><strong>Success</strong> The creature takes half damage.</p>\n<p><strong>Failure</strong> The creature takes full damage and becomes @UUID[Compendium.pf2e.conditionitems.Item.Enfeebled]{Enfeebled 1} for 1 hour.</p>\n<p><strong>Critical Failure</strong> The creature takes full damage, becomes @UUID[Compendium.pf2e.conditionitems.Item.Enfeebled]{Enfeebled 2} for 1 hour, and becomes @UUID[Compendium.pf2e.conditionitems.Item.Drained]{Drained 1}. If the creature is already drained, it instead increases the value of its drained condition by 1.</p>"
                },
                "frequency": {
                    "max": 1,
                    "per": "round"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
                    "value": []
                }
            },
            "type": "action"
        }
