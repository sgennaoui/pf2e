        {
            "_id": "kBFbgghKAAosHaNp",
            "_stats": {
                "compendiumSource": "Compendium.pf2e.pathfinder-monster-core.Actor.2p7MEk4SdXfLbzxO.Item.TAIcUgt3JKg5c7fV"
