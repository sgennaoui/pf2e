                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p>Brensen dips his cap into red wine or blood from a slain foe. Wine must have been opened by Brensen within the last minute. Blood must be from a creature Brensen helped kill and must have died within the last minute. He gains a +4 status bonus to damage rolls and Fortitude saves for 1 minute.</p>\n<p>@UUID[Compendium.pf2e.bestiary-effects.Item.Effect: Blood Soak]</p>"
