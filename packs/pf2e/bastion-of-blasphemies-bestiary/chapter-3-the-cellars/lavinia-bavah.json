        {
            "_id": "DizgIQWDiExoFfGl",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Infect Shame",
            "sort": 600000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p>Lavinia stares at a creature she can see within 30 feet, and transfers her overwhelming shame into that creature's mind. That creature takes @Damage[3d6[mental]] damage and must attempt a @Check[will|dc:22|inflicts:slowed] save with the following effects.</p><hr /><p><strong>Critical Success</strong> No effect and temporarily immune for 1 minute.</p>\n<p><strong>Success</strong> The creature takes half damage.</p>\n<p><strong>Failure</strong> The creature takes full damage, and is @UUID[Compendium.pf2e.conditionitems.Item.Slowed]{Slowed 1} for 1 round as they agonize internally over its shame.</p>\n<p><strong>Critical Failure</strong> As failure, but double damage and slowed 1 for 1 minute.</p>"
                },
                "publication": {
