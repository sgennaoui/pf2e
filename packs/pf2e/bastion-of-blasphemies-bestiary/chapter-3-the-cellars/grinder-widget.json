        {
            "_id": "ZMxrbMShYOtO3gEG",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Infiltration Tools",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "interaction",
                "description": {
                    "value": "<p>A dig-widget's face consists of a set of @UUID[Compendium.pf2e.equipment-srd.Item.Thieves' Toolkit (Infiltrator)]{Infiltrator Thieves' Tools}. They can be salvaged from a destroyed dig-widget with a successful @Check[crafting|dc:20|name:Salvage Infiltration Tools] check. On a failed check, the tools are destroyed.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
