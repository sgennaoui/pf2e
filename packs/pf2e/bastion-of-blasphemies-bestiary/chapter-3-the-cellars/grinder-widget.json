        },
        {
            "_id": "nYQgnHNVs60rcvUn",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Mechanical Vulnerability",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>A creature with expert proficiency in Thievery can attempt a check to [[/act disable-device dc=20]] to damage a dig-widget. The DC is 20, and each success deals @Damage[18[untyped]] damage.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
                    "value": []
