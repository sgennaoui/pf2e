            "folder": "Gg8SQFKssgHH6OUz",
            "img": "systems/pf2e/icons/actions/OneAction.webp",
            "name": "Consume Flesh",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The ghoul is adjacent to the corpse of a creature that died within the last hour.</p><hr /><p><strong>Effect</strong> The ghoul devours a chunk of the corpse and regains @Damage[5d6[healing]] Hit Points.</p>\n<p>It can regain Hit Points from any given corpse only once.</p>"
                },
                "publication": {
                    "license": "ORC",
                    "remaster": true,
                    "title": "Pathfinder Monster Core"
                },
                "rules": [],
                "slug": "ghoul-consume-flesh",
                "traits": {
                    "value": [
                        "manipulate"
                    ]
                }
            },
            "type": "action"
        },
        {
            "_id": "5feVHCheqU7Ymlxr",
            "_stats": {
                "compendiumSource": "Compendium.pf2e.bestiary-family-ability-glossary.Item.pOW2IvfVusdmD5v5"
