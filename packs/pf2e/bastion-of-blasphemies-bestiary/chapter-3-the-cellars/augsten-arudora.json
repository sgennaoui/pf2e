                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> Augsten is carrying his cudgel in one hand</p>\n<p><strong>Frequency</strong> once per round</p><hr /><p><strong>Effect</strong> Augsten smashes his cudgel against an adjacent creature with astonishing force, dealing @Damage[3d8[bludgeoning]] damage and forcing the target to attempt a @Check[fortitude|dc:26] save.</p><hr /><p><strong>Critical Success</strong> The creature takes no damage.</p>\n<p><strong>Success</strong> The creature takes half damage.</p>\n<p><strong>Failure</strong> The creature takes full damage and is @UUID[Compendium.pf2e.conditionitems.Item.Off-Guard] until the start of its next turn.</p>\n<p><strong>Critical Failure</strong> The creature takes double damage, is knocked @UUID[Compendium.pf2e.conditionitems.Item.Prone], and is off-guard until the start of its next turn.</p>"
                },
