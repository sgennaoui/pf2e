        {
            "_id": "nTnXWJm9Sl3PVC60",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Skull-Faced Servant",
            "sort": 900000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>A servitor phantom's head is that of an animal skull, as determined by their original role in the castle before the curse fell. This skull head grants the servitor phantom a horns or jaws Strike (as appropriate). Each type of skull is associated with a different Lore skill.</p>\n<p><strong>Brewers</strong> have deer skulls and Alcohol Lore.</p>\n<p><strong>Cooks</strong> have bird skulls and Cooking Lore.</p>\n<p><strong>Housekeepers</strong> have cat skulls and Labor Lore.</p>\n<p><strong>Valets</strong> have dog skulls and Labor Lore.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
                    "value": []
