        {
            "_id": "tPFPJ6LSgiPujB33",
            "_stats": {
                "compendiumSource": "Compendium.pf2e.book-of-the-dead-bestiary.Actor.ol2lji9lH7PXh1uw.Item.b4tdi1u14a8xwxkz"
            },
            "img": "systems/pf2e/icons/actions/FreeAction.webp",
            "name": "Change of Luck",
            "sort": 700000,
            "system": {
                "actionType": {
                    "value": "free"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Frequency</strong> once per day</p>\n<p><strong>Trigger</strong> A creature within 30 feet of the bone croupier attempts a check but hasn't rolled the check yet</p>\n<hr />\n<p><strong>Effect</strong> The bone croupier pulls on the threads of luck that bind all things. The target rolls twice, and then the bone croupier decides which result applies. If the bone croupier chooses the lower roll, this is a misfortune effect; if the bone croupier chooses the higher roll, it's a fortune effect; if they're the same, the croupier decides which trait to apply. If this ability is expended, the bone croupier rolls [[/br 2d6 #Recharge Change of Luck]] at the start of each of their turns, recharging the ability if the sum is 7 or 11.</p>"
                },
                "frequency": {
                    "max": 1,
                    "per": "day",
                    "value": 1
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
