        {
            "_id": "6CKierkkY3pJRTtl",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Rhapsodic Flourish",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "reaction"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p><strong>Trigger</strong> The Ghostlight Sister would roll a save against an auditory or sonic effect</p><hr /><p><strong>Effect</strong> The Ghostlight Sister performs a refrain that deflects sonic vibrations and rolls a @Check[performance] check in place of the triggering saving throw. Sonic feedback rebounds from the effect, dealing @Damage[1d6[sonic]] damage to the source of the triggering effect if the Performance check succeeded or @Damage[2d6[sonic]] damage to the Ghostlight Sister on a failure.</p>"
                },
