        {
            "_id": "SCQ9iLRoaHPOluaU",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Hooked",
            "sort": 700000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>A creature struck by Arth's fish hook is skewered, taking @Damage[1d4[persistent,bleed]] damage as long as the hook remains stuck. A creature can [[/act escape dc=28]] from the hook.</p>"
                },
