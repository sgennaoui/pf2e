            "type": "action"
        },
        {
            "_id": "NpfYo9pZdjLrFsyx",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Maimed But Alive",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>If Voldrak would kill a creature with damage from his bite or tail Strike, he can opt instead to reduce the creature to 1 Hit Point and maim it, causing the creature to become permanently @UUID[Compendium.pf2e.conditionitems.Item.Enfeebled]{Enfeebled 3} or @UUID[Compendium.pf2e.conditionitems.Item.Clumsy]{Clumsy 3} (Voldrak's choice) from the horrific wound.</p>"
                },
