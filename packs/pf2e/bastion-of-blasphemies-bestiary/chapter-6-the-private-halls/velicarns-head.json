        {
            "_id": "olWY4YLhwbHPKukq",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Rupturing Shriek",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p>Velicarn's head unleashes a horrific howl that causes blood to leak out of those who hear it and into his gaping open mouth. All creatures within 30 feet must succeed at a @Check[fortitude|dc:28|options:area-effect,inflicts:drained] save or become @UUID[Compendium.pf2e.conditionitems.Item.Drained]{Drained 1} (@UUID[Compendium.pf2e.conditionitems.Item.Drained]{Drained 2} on a critical failure) as some of their blood runs from their bodies into Velicarn's maw. Creatures currently taking persistent bleed damage take a –2 circumstance penalty to this saving throw. Velicarn's head regains @Damage[5[healing]] Hit Points for every creature in the area, to a maximum of @Damage[25[healing]] Hit Points, and he can't use Rupturing Shriek again for [[/gmr 1d4 #Recharge Rupturing Shriek]]{1d4 rounds}.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
                    "value": [
                        "auditory",
                        "curse",
                        "divine",
                        "emotion",
                        "fear",
                        "mental"
                    ]
                }
            },
            "type": "action"
        },
        {
