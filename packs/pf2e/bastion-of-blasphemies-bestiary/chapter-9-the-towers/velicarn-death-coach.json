        {
            "_id": "oc9MYqF7j7JvUtJu",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Aura of Doom",
            "sort": 800000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>30 feet. A living creature that enters the area must succeed at a @Check[will|dc:33|options:area-effect,inflicts:doomed] save or gain the @UUID[Compendium.pf2e.conditionitems.Item.Doomed]{Doomed 1} condition. A critical failure increases this condition to @UUID[Compendium.pf2e.conditionitems.Item.Doomed]{Doomed 2}. Regardless of the result of the saving throw, the creature is temporarily immune to Velicarn's aura of doom for 1 minute.</p>"
                },
                "publication": {
