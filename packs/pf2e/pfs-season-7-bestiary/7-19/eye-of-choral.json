        {
            "_id": "II51rmEX3NRS3rAe",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Key Sense",
            "sort": 700000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>The Eye of Choral was created alongside several magical keys. It can sense the presence of these keys anywhere in Rahasia Rinca, communicate telepathically with anyone bearing a key within the complex, and always knows whether a creature possesses such a key.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
