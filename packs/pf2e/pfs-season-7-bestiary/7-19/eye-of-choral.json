        {
            "_id": "wWFynturzRrVqvWi",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Shadow Construct",
            "sort": 900000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>The Eye of Choral is only semi-real. The first time each round a PC is hit by one of the Eye's Strikes, the creature makes a @Check[will|dc:23] save to realize the creature's attacks aren't wholly real. The result applies to the damage of that Strike and lasts until the start of the creature's next turn.</p><hr /><p><strong>Critical Success</strong> The creature gains resistance to damage from the Eye's Strikes equal to its level.</p>\n<p><strong>Success</strong> The creature gains resistance to damage from the Eye's Strikes equal to half its level.</p>\n<p><strong>Failure</strong> The creature is affected by the Eye's Strikes as normal.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "key": "Immunity",
                        "mode": "remove",
                        "type": [
                            "doomed",
                            "drained",
                            "fatigued",
                            "healing",
                            "nonlethal-attacks",
                            "sickened",
                            "spirit",
                            "vitality",
                            "void"
                        ]
                    }
                ],
                "slug": null,
                "traits": {
                    "value": [
                        "illusion"
                    ]
                }
            },
            "type": "action"
        },
        {
