                                            "item:type:melee",
                                            "item:type:weapon"
                                        ]
                                    }
                                ],
                                "label": "PF2E.IWR.Custom.StrikesCreatureSheddingBrightLight"
                            }
                        ],
                        "key": "Resistance",
                        "type": "physical",
                        "value": 15
                    }
                ],
