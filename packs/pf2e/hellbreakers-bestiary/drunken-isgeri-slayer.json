                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p><strong>Trigger</strong> The drunken Isgeri Slayer is hit with an attack that deals physical damage</p><hr /><p><strong>Effect</strong> The drunken slayer stumbles away from the blow. They gain resistance 2 to the damage of the triggering attack and they can Step. They also take a –1 circumstance penalty to AC for 1 round.</p>\n<p>@UUID[Compendium.pf2e.bestiary-effects.Item.Effect: Drunken Stumble]</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
