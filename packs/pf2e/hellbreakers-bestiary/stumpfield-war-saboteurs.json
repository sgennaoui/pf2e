        },
        {
            "_id": "SzGWtFMZlNoEwZaz",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Slapstick Traps",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The saboteurs' last action was to successfully Hide</p><hr /><p><strong>Effect</strong> The saboteurs laid down falling obstacles as they move unseen. The saboteurs @UUID[Compendium.pf2e.actionspf2e.Item.Sneak] twice. Until the beginning of the saboteurs' next turn, any non-ally creature that moves into a square that the saboteurs snuck through takes @Damage[5d8[bludgeoning]] damage (@Check[reflex|dc:24|basic] save). On a critical failure, the creature also falls @UUID[Compendium.pf2e.conditionitems.Item.Prone]. Once this trap has been triggered, the rest of the squares the saboteurs snuck through become difficult terrain until a creature spends 1 hour clearing it.</p>"
                },
                "frequency": {
                    "max": 1,
                    "per": "PT1M"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
