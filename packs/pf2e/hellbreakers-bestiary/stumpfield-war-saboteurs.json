            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Slice and Dice!",
            "sort": 600000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Frequency</strong> once per round</p><hr /><p><strong>Effect</strong> The saboteurs engage in a coordinated melee attack against each enemy in a @Template[type:emanation|distance:5], with a @Check[reflex|dc:21|basic|options:area-effect] save. The damage dealt depends on the number of actions.</p>\n<p><span class=\"action-glyph\">1</span> @Damage[1d8[slashing]|options:area-damage] damage</p>\n<p><span class=\"action-glyph\">2</span> @Damage[(2d8+5)[slashing]|options:area-damage] damage</p>\n<p><span class=\"action-glyph\">3</span> @Damage[(2d8+9)[slashing]|options:area-damage] damage</p>"
                },
