        {
            "_id": "dvv7qTPvf2sO7Ca3",
            "img": "systems/pf2e/icons/actions/OneThreeActions.webp",
            "name": "Frenzied Feast",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Frequency</strong> once per round</p><hr /><p><strong>Effect</strong> The warband launches a frenzy of attacks against each enemy in a @Template[type:emanation|distance:5] with a @Check[reflex|dc:26|basic] save. The damage depends on the number of actions. For each enemy damaged by this attack, the damage of the attack increases by 1d4 piercing for all targets (up to a maximum of 3d4 additional damage).</p>\n<p><span class=\"action-glyph\">1</span> @Damage[(1d6+3)[piercing]|options:area-damage] damage plus @Damage[1d4[persistent,bleed]|options:area-damage] damage</p>\n<p><span class=\"action-glyph\">2</span> @Damage[(2d6+6)[piercing]|options:area-damage] damage plus @Damage[1d6[persistent,bleed]|options:area-damage] damage</p>\n<p><span class=\"action-glyph\">3</span> @Damage[(3d6+9)[piercing]|options:area-damage] damage plus @Damage[1d8[persistent,bleed]|options:area-damage] damage</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
