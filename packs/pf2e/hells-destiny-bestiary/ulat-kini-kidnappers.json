            "img": "systems/pf2e/icons/actions/OneAction.webp",
            "name": "Spoils of War",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The kidnappers' last action was Let 'em Have It and at least one creature failed its save</p><hr /><p><strong>Effect</strong> The ulat-kini kidnappers attempts to [[/act steal]] one object from each enemy that failed its save, even if the enemy is in combat or on guard.</p>"
                },
