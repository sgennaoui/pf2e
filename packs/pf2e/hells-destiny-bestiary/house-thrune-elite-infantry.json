        {
            "_id": "B2xSj2M2JBt6C0XP",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Give No Ground",
            "sort": 100000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>These soldiers have had it beaten into them that they shall hold their ground no matter what. If any effect would force the House Thrune elite infantry to move, reduce that distance by 10 feet. Any time it would be affected by the @UUID[Compendium.pf2e.conditionitems.Item.Fleeing] condition, the elite infantry is instead @UUID[Compendium.pf2e.conditionitems.Item.Slowed]{Slowed 2} for the same duration.</p>"
                },
