        {
            "_id": "V5g0qZhLRkme45qX",
            "img": "systems/pf2e/icons/actions/ThreeActions.webp",
            "name": "Boarding Grapple",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 3
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The Hellknights are on a ship</p><hr /><p><strong>Effect</strong> The Hellknights throw a volley of grappling hooks at a 10-foot-radius burst within 30 feet. Five grappling hooks landing at random squares in the burst take hold, and the Hellknights heave, forcibly moving both ships up to 15 feet toward each other until they're adjacent to each other. The ships remain adjacent to each other until all five of the grappling hooks are dislodged (each as an Interact action) or their respective chains are broken (Hardness 8, HP 20, BT 10).</p>"
                },
                "publication": {
                    "license": "OGL",
