            "img": "systems/pf2e/icons/actions/OneThreeActions.webp",
            "name": "Flail Assault",
            "sort": 800000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Frequency</strong> once per round</p><hr /><p><strong>Effect</strong> The dragoons lash out with their flails in a melee attack against each enemy in a @Template[type:emanation|distance:5] (@Check[reflex|dc:25|basic] save). The damage depends on the number of actions.</p>\n<p><span class=\"action-glyph\">1</span> @Damage[(1d8+2)[bludgeoning]|options:area-damage]</p>\n<p><span class=\"action-glyph\">2</span> @Damage[(2d8+9)[bludgeoning]|options:area-damage]</p>\n<p><span class=\"action-glyph\">3</span> @Damage[(3d8+11)[bludgeoning]|options:area-damage]</p>"
                },
