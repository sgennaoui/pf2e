        {
            "_id": "gP9xV4BDHAN65B94",
            "img": "systems/pf2e/icons/actions/Reaction.webp",
            "name": "Bind Them in Chains",
            "sort": 200000,
            "system": {
                "actionType": {
                    "value": "reaction"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p><strong>Trigger</strong> A creature or troop adjacent to the dragoon squad gains the frightened condition, or an adjacent troop is reduced to 2 segments</p><hr /><p><strong>Effect</strong> Sensing their foes' faltering morale, the dragoons lash out with their manacles. The triggering creature must attempt a @Check[reflex|dc:25] save.</p><hr /><p><strong>Critical Success</strong> The creature is unaffected.</p>\n<p><strong>Success</strong> The creature becomes @UUID[Compendium.pf2e.conditionitems.Item.Clumsy]{Clumsy 1} until the end of the squad's next turn.</p>\n<p><strong>Failure</strong> The creature becomes @UUID[Compendium.pf2e.conditionitems.Item.Clumsy]{Clumsy 2} until the end of the squad's next turn and is @UUID[Compendium.pf2e.conditionitems.Item.Immobilized] until it [[/act escape dc=25]]{Escapes}.</p>\n<p><strong>Critical Failure</strong> As failure, but @UUID[Compendium.pf2e.conditionitems.Item.Restrained] instead of immobilized.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
                    "value": []
                }
            },
