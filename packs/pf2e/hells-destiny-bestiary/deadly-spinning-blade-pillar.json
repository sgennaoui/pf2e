            },
            "publication": {
                "license": "ORC",
                "remaster": true,
                "title": "Pathfinder Adventure Path: Hell's Destiny"
            },
            "reset": "<p>The trap deactivates and resets after 1 minute.</p>",
            "routine": "<p>(3 actions) The trap uses its first action to make a spinning blade Strike against each adjacent creature. Its second action is to move in a random direction (roll 1d4 to determine the direction), and its third action to make a spinning blade Strike against each adjacent creature.</p>"
