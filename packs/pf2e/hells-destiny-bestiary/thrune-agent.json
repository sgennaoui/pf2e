                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>The agent deals an additional 3d6 precision damage to creatures that are @UUID[Compendium.pf2e.conditionitems.Item.Off-Guard] to them.</p>"
