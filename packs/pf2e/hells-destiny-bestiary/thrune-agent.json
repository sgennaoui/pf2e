            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The agent's last action was a successful Strike against an @UUID[Compendium.pf2e.conditionitems.Item.Off-Guard] creature</p><hr /><p><strong>Effect</strong> Until the end of the agent's next turn, the target takes a –10-foot status penalty to its Speeds or becomes @UUID[Compendium.pf2e.conditionitems.Item.Enfeebled]{Enfeebled 1}. The agent decides which penalty to apply.</p>\n<p>@UUID[Compendium.pf2e.feat-effects.Item.Effect: Debilitating Strike]</p>"
