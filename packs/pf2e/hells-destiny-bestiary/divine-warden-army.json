        {
            "_id": "anYe0Rfu4UuxyNt2",
            "img": "systems/pf2e/icons/actions/TwoActions.webp",
            "name": "Divine Lance Fusillade",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p>The divine warden army unleashes beams of divine energy. This fusillade is a @Template[type:burst|distance:10] within 60 feet that deals @Damage[9d6[spirit]|options:area-damage] damage with a @Check[reflex|dc:37|basic|traits:holy,magical] save. When the divine warden army is reduced to 2 segments, this area decreases to a @Template[type:burst|distance:5].</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
