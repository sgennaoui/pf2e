                    ]
                }
            },
            "type": "action"
        },
        {
            "_id": "xQgIoQdSRqQOY51E",
            "img": "systems/pf2e/icons/actions/OneThreeActions.webp",
            "name": "Holy Blades",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p>The divine wardens make coordinated melee attacks with their swords. Each enemy within a @Template[type:emanation|distance:5] must attempt a @Check[reflex|dc:37|basic] save. The damage depends on the number of actions.</p>\n<p><span class=\"action-glyph\">1</span> @Damage[(2d8+1)[slashing]|options:area-damage] damage</p>\n<p><span class=\"action-glyph\">2</span> @Damage[(4d8+12)[slashing]|options:area-damage] damage</p>\n<p><span class=\"action-glyph\">3</span> @Damage[(6d8+13)[slashing]|options:area-damage] damage</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
