        },
        {
            "_id": "3OBMYuGwBnj1yIPD",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Orchestra of Faith",
            "sort": 600000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>The divine warden army is a beacon for the faithful. A cleric of Iomedae can channel a @UUID[Compendium.pf2e.spells-srd.Item.Heal] spell through a divine warden they can see within 60 feet. The cleric determines any targets or area for the spell as if they were standing in a space of the divine warden army of their choosing.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
                    "value": []
                }
            },
            "type": "action"
        }
