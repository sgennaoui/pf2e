        },
        {
            "_id": "lEO7Z3PavizGJcvk",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Vicious Cruelty",
            "sort": 700000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>A creature that has the clumsy, enfeebled, @UUID[Compendium.pf2e.conditionitems.Item.Immobilized], or @UUID[Compendium.pf2e.conditionitems.Item.Restrained] condition takes an additional 1d6 precision damage from Merciless Tridents (2d6 precision damage if the levalochs take 2 or 3 actions).</p>"
                },
