        {
            "_id": "3XQkhOGtUD3EhhF4",
            "img": "systems/pf2e/icons/actions/Reaction.webp",
            "name": "Dance Partner",
            "sort": 300000,
            "system": {
                "actionType": {
                    "value": "reaction"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p><strong>Trigger</strong> An adjacent creature whom the mannequin dealt damage to with a fist Strike since the beginning of the mannequin's last turn attempts to move away from the mannequin</p><hr /><p><strong>Effect</strong> The mannequin dances after the triggering creature, either Climbing or Striding, following the creature and staying in reach throughout its movement until the creature stops moving or the mannequin has moved up to its full Speed, whichever happens first. The mannequin gains a +2 circumstance bonus to AC and Reflex saves against reactions triggered by its movement. If it critically succeeds at a Reflex save against a reaction triggered by its movement (or if the attacker critically fails its attack roll or check), the mannequin maneuvers the creature it's following so that the latter is exposed to the reaction; the attacker rerolls the attack roll or check against the followed creature or forces the followed creature to attempt a Reflex save against the reaction instead.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "domain": "all",
                        "key": "RollOption",
                        "option": "dance-partner",
                        "toggleable": true
                    },
                    {
                        "key": "FlatModifier",
                        "predicate": [
                            "dance-partner"
                        ],
                        "selector": [
                            "ac",
                            "reflex"
                        ],
                        "type": "circumstance",
                        "value": 2
                    }
                ],
                "slug": null,
                "traits": {
