        },
        {
            "_id": "vljXyh1cHVJGwrxm",
            "img": "systems/sf2e/icons/default-icons/action.svg",
            "name": "Slip Through Space",
            "sort": 600000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Frequency</strong> once per round</p><hr /><p><strong>Effect</strong> The anchored dimensional takes advantage of its tenuous relationship with space and time to outmaneuver threats. The anchored dimensional teleports to an unoccupied space they can see within 15 feet.</p>"
                },
