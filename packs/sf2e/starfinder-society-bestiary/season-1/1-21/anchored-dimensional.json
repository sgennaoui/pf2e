        {
            "_id": "J0lA8DKxTp3JXWCT",
            "img": "systems/sf2e/icons/default-icons/action.svg",
            "name": "Opportunistic Rotation",
            "sort": 300000,
            "system": {
                "actionType": {
                    "value": "reaction"
                },
                "actions": {
                    "value": null
                },
                "category": "interaction",
                "description": {
                    "value": "<p><strong>Trigger</strong> The anchored dimensional would be hit by a melee or ranged Strike</p>\n<p><strong>Requirements</strong> The anchored dimensional is aware of the attack and is not @UUID[Compendium.sf2e.conditions.Item.Off-Guard] against them</p><hr /><p><strong>Effect</strong> The anchored dimensional spins their body, causing the stabilization ring to rotate into the way of the attack. The triggering Strike's damage is dealt to the stabilization ring, rather than the anchored dimensional. All other effects of the Strike affect the anchored dimensional.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
