        {
            "_id": "fzBwBZEB8PPBVoTj",
            "img": "systems/sf2e/icons/default-icons/action.svg",
            "name": "Scatter Light",
            "sort": 300000,
            "system": {
                "actionType": {
                    "value": "reaction"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p><strong>Trigger</strong> The facet guardian is damaged by an attack with the light trait or a weapon from the laser group</p><hr /><p><strong>Effect</strong> The facet guardian reflexively positions its facets to scatter the light in all directions. It gains resistance 5 to the triggering damage and creatures adjacent to the facet guardian take damage equal to the amount of damage resisted this way (@Check[reflex|dc:18|basic]).</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "key": "RollOption",
                        "option": "scatter-light",
                        "toggleable": true
                    },
                    {
                        "definition": [
                            {
                                "or": [
                                    "item:trait:light",
                                    "item:group:laser"
                                ]
                            }
                        ],
