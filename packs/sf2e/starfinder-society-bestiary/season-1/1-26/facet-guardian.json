                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>When the facet guardian critically succeeds on a focused reflection Strike, the target must attempt a @Check[fortitude|dc:18] save or be @UUID[Compendium.sf2e.conditions.Item.Dazzled] for 1 round.</p>"
