                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p>Arnyn rearranges their skeleton to adapt to their circumstances. They choose between squat, lanky, or flexible. If they take on the squat shape, they gain a +2 circumstance bonus to Athletics checks to [[/act force-open]]. If they choose lanky, they gain a +2 circumstance bonus to Acrobatics checks to [[/act squeeze]]. If they choose flexible, their reach increases to 10 feet with held melee weapons.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "alwaysActive": true,
                        "key": "RollOption",
                        "option": "adjust-shape",
                        "selection": "squat",
                        "suboptions": [
