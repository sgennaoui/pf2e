        {
            "_id": "SljsbK1S3pR47Mm0",
            "img": "systems/sf2e/icons/actions/Passive.webp",
            "name": "Disorganized Emotions",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>When a mosaic soul fails a saving throw against an emotion effect, a single solid hue takes over its form, and it loses the incorporeal trait for [[/gmr 1d4 #rounds]]{1d4 rounds}. During this time, the mosaic soul can't use Swirling Colors, and its strange light aura is disabled.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
