        {
            "_id": "TLohaBo6PxqfdIN5",
            "img": "systems/sf2e/icons/actions/Passive.webp",
            "name": "Mutating Touch",
            "sort": 1300000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>A hesper can deliver an enormous, mutating dose of radiation with a touch. Creatures struck by a hesper's fist Strike must attempt a @Check[fortitude|dc:18] save. On a failure, the creature gains a random mutation from the table below for 1 hour (or 24 hours on a critical failure).</p><table class=\"pf2e\"><thead><tr><th>[[/r 1d8]]</th><th>Mutation</th></tr></thead><tbody><tr><td>1</td><td><strong>Extra eyes:</strong> Target is dazzled in bright light and gains a +2 status bonus to sight-based Perception checks.</td></tr><tr><td>2</td><td><strong>Bioelectric cells:</strong> Tech items held by the target regain all spent charges at the end of the creature's turn. Tech items are glitching 1 for as long as the target holds them. If the target is a creature with the tech trait, it becomes glitching 1, and its melee Strikes deal an additional @Damage[1d6[electricity]] damage.</td></tr><tr><td>3</td><td><strong>Spikes:</strong> Target gains an unarmed melee attack that deals @Damage[1d4[piercing]] damage. It takes a –2 status penalty to attack rolls with two-handed weapons.</td></tr><tr><td>4</td><td><strong>Glowing Tumors:</strong> Target sheds light as a flashlight and takes a –2 status penalty to Stealth checks.</td></tr><tr><td>5</td><td><strong>Gills:</strong> Target gains the amphibious trait and takes a –1 status penalty to Fortitude saves.</td></tr><tr><td>6</td><td><strong>Musk gland:</strong> Target gains a 30-foot stench aura with a DC equal to their class DC.</td></tr><tr><td>7</td><td><strong>Protective growths:</strong> Target gains a +1 status bonus to AC and takes a –2 status penalty to Dexterity-based checks.</td></tr><tr><td>8</td><td><strong>Cellular alteration:</strong> The target is @UUID[Compendium.sf2e.conditions.Item.Sickened] for the duration and gains @UUID[Compendium.sf2e.bestiary-ability-glossary-srd.Item.Fast Healing] with a value equal to half its level (rounded up).</td></tr></tbody></table>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
                "traits": {
                    "value": []
                }
            },
            "type": "action"
        },
