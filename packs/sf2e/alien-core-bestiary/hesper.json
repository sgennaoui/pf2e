                    "value": ""
                },
                "counteraction": false,
                "damage": {},
                "defense": null,
                "description": {
                    "value": "<p>You vitalize and stimulate the target at a cellular level, giving it a temporary burst of energy that unfortunately takes an exhausting toll. The target gains the @UUID[Compendium.sf2e.conditions.Item.Quickened] condition and can use the extra action to Stride or Strike. After that round ends, the target becomes @UUID[Compendium.sf2e.conditions.Item.Fatigued] until it can rest for 10 minutes.</p><hr /><p><strong>Heightened (6th)</strong> You can target up to six creatures by using 2 actions to Cast this Spell.</p>"
                },
                "duration": {
                    "sustained": false,
                    "value": "1 round"
                },
                "heightening": {
                    "levels": {
                        "6": {
                            "target": {
                                "value": "Up to 6 willing living creatures that aren't fatigued or quickened"
                            }
                        }
