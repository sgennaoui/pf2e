        {
            "_id": "hknftzcCPHfGauT6",
            "img": "systems/sf2e/icons/actions/TwoActions.webp",
            "name": "Merge",
            "sort": 1200000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The hesper has spent at least 1 hour in contact with a reactor or other large power source</p><hr /><p><strong>Effect</strong> The hesper Strides into the reactor, passing through its exterior and gaining fast healing 5 while inside. The hesper is aware of but can't physically interact with their surroundings and is protected from those outside. If the reactor is broken, the hesper takes @Damage[2d10[force]] damage and is immediately expelled from it. If the reactor is destroyed while the hesper is inside, the hesper must succeed at a @Check[fortitude|dc:15] save or be slain instantly.</p>"
                },
                "publication": {
